# Development environment variables (mock keys for local development)
# Copy this file to .env.dev and update with your actual keys

# Environment
ENVIRONMENT=development
PYTHONUNBUFFERED=1

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mistral AI (for LLM-based recommendations)
MISTRAL_API_KEY=mock-key-for-dev

# Google Earth Engine (for satellite NDVI data)
GEE_SERVICE_ACCOUNT=mock-gee-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=./keys/gee-private-key.json

# India Meteorological Department (IMD)
IMD_API_KEY=mock-imd-api-key
IMD_API_URL=https://imdapi.example.com

# OpenWeatherMap (fallback for weather data)
OPENWEATHER_API_KEY=mock-openweather-api-key

# AGMARKNET (mandi prices - public API, no key required)
AGMARKNET_API_URL=https://agmarknet.gov.in/api

# Redis (caching - optional for development)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=DEBUG
